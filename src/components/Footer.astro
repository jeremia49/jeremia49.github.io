---
import { site } from '../data/site';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="wrap">
    <span>© {year} {site.name}</span>
    <span>
      <a href={`mailto:${site.email}`}>Email</a> ·
      <a href={site.github}>GitHub</a> ·
      <a href={site.orcid}>ORCID</a>
    </span>
  </div>
</footer>
