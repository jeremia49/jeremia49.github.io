---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  site, about, employment, education, publications,
  skills, awards, certifications,
} from '../data/site';
---
<BaseLayout title="About" description={about.summary}>
  <section class="page-head">
    <h1>About</h1>
    <p>{site.title}</p>
  </section>

  <p>{about.summary}</p>
  <div class="hero-links">
    <a class="btn" href={`mailto:${site.email}`}>{site.email}</a>
    <a class="btn" href={site.github}>GitHub</a>
    <a class="btn" href={site.orcid}>ORCID</a>
  </div>

  <h2>Employment</h2>
  <div class="section">
    {employment.map((e) => (
      <div class="entry">
        <div class="entry-head">
          <span class="entry-title">{e.role} · <span class="entry-org">{e.org}</span></span>
          <span class="entry-period">{e.period}</span>
        </div>
        <ul>{e.points.map((p) => <li>{p}</li>)}</ul>
      </div>
    ))}
  </div>

  <h2>Education</h2>
  <div class="section">
    {education.map((e) => (
      <div class="entry">
        <div class="entry-head">
          <span class="entry-title">{e.degree} · <span class="entry-org">{e.org}</span></span>
          <span class="entry-period">{e.period}</span>
        </div>
        {e.detail && <p style="margin: 6px 0 0; color: var(--text-muted); font-size: 0.92rem;">{e.detail}</p>}
      </div>
    ))}
  </div>

  <h2>Research Publications</h2>
  <div class="section">
    {publications.map((p) => (
      <div class="entry">
        <div class="entry-title">{p.title}</div>
        <p style="margin: 4px 0 0; color: var(--text-muted); font-size: 0.9rem;">{p.authors}</p>
        <p style="margin: 2px 0 0; color: var(--text-muted); font-size: 0.88rem;">
          {p.venue}. <a href={p.doi}>DOI ↗</a>
        </p>
      </div>
    ))}
  </div>

  <h2>Skills</h2>
  <div class="section">
    {skills.map((s) => (
      <div class="entry">
        <div class="entry-head"><span class="entry-title">{s.group}</span></div>
        <div class="chips" style="margin-top: 8px;">
          {s.items.map((i) => <span class="chip chip-tech">{i}</span>)}
        </div>
      </div>
    ))}
  </div>

  <h2>Awards & Achievements</h2>
  <div class="section">
    {awards.map((a) => (
      <div class="entry">
        <div class="entry-head">
          <span class="entry-title">{a.title}</span>
          <span class="entry-period">{a.year}</span>
        </div>
        <p style="margin: 4px 0 0; color: var(--text-muted); font-size: 0.9rem;">{a.org}</p>
      </div>
    ))}
  </div>

  <h2>Certifications</h2>
  <div class="section">
    {certifications.map((c) => (
      <div class="entry">
        <div class="entry-head">
          <span class="entry-title">{c.title}</span>
          <span class="entry-period">{c.year}</span>
        </div>
        <p style="margin: 4px 0 0; color: var(--text-muted); font-size: 0.9rem;">{c.org}</p>
      </div>
    ))}
  </div>
</BaseLayout>
