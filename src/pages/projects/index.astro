---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const withBase = (href: string) => ('/' + base + href).replace(/\/+/g, '/');

const projects = (await getCollection('projects', (p) => !p.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="Projects" description="Portfolio of projects, research and builds by Jeremia Manurung.">
  <section class="page-head">
    <h1>Projects</h1>
    <p>Things I have built and researched — web, mobile, games and applied AI/ML.</p>
  </section>

  {projects.length === 0 ? (
    <p style="color: var(--text-muted);">No projects yet. See README.md for how to add one.</p>
  ) : (
    <div class="grid">
      {projects.map((p) => (
        <ProjectCard
          href={withBase(`/projects/${p.id}`)}
          title={p.data.title}
          description={p.data.description}
          date={p.data.date}
          cover={p.data.cover}
          tags={p.data.tags}
        />
      ))}
    </div>
  )}
</BaseLayout>
