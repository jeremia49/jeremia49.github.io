---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const withBase = (href: string) => ('/' + base + href).replace(/\/+/g, '/');

const posts = (await getCollection('blog', (p) => !p.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="Blog" description="Articles, notes and activity logs by Jeremia Manurung.">
  <section class="page-head">
    <h1>Blog</h1>
    <p>Articles, notes and documentation of activities. <a href={withBase('/rss.xml')}>RSS</a></p>
  </section>

  {posts.length === 0 ? (
    <p style="color: var(--text-muted);">No posts yet. See README.md for how to add one.</p>
  ) : (
    <div class="section">
      {posts.map((p) => {
        const dateStr = p.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
        return (
          <div class="entry">
            <div class="entry-head">
              <a class="entry-title" href={withBase(`/blog/${p.id}`)}>{p.data.title}</a>
              <span class="entry-period">{dateStr}</span>
            </div>
            <p style="margin: 6px 0 0; color: var(--text-muted); font-size: 0.95rem;">{p.data.description}</p>
            {p.data.tags.length > 0 && (
              <div class="chips" style="margin-top: 8px;">
                {p.data.tags.map((t) => <span class="chip">{t}</span>)}
              </div>
            )}
          </div>
        );
      })}
    </div>
  )}
</BaseLayout>
