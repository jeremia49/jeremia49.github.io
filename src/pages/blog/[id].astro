---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', (p) => !p.data.draft);
  return posts.map((p) => ({ params: { id: p.id }, props: { entry: p } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const base = import.meta.env.BASE_URL;
const withBase = (href: string) => ('/' + base + href).replace(/\/+/g, '/');
const dateStr = d.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title={d.title} description={d.description} image={d.cover?.src}>
  <a class="back-link" href={withBase('/blog')}>← All posts</a>
  <h1>{d.title}</h1>
  <div class="meta-row">
    <span>{dateStr}</span>
    {d.updated && <span>· updated {d.updated.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>}
    {d.tags.length > 0 && (
      <span class="chips">{d.tags.map((t) => <span class="chip">{t}</span>)}</span>
    )}
  </div>

  {d.cover && <Image src={d.cover} alt={d.title} widths={[480, 960, 1440]} sizes="100vw" />}

  <article class="prose" style="margin-top: 24px;">
    <Content />
  </article>
</BaseLayout>
