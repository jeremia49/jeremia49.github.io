---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  site, about, employment, education, publications,
  skills, awards, certifications,
} from '../data/site';

type Attachment = {
  label?: string;
  href: string;
  type?: 'jpg' | 'pdf' | 'url';
};

type CredentialItem = {
  title: string;
  year: string;
  org: string;
  attachments?: Attachment[];
};

const getAttachmentLabel = (attachment: Attachment) => {
  if (attachment.label) return attachment.label;
  if (attachment.type === 'jpg') return 'JPG';
  if (attachment.type === 'pdf') return 'PDF';
  return 'URL';
};

const getAttachmentType = (href: string): Attachment['type'] => {
  const cleanHref = href.split(/[?#]/)[0].toLowerCase();
  if (/\.(jpe?g)$/.test(cleanHref)) return 'jpg';
  if (/\.pdf$/.test(cleanHref)) return 'pdf';
  return 'url';
};

const normalizeAttachments = (item: CredentialItem) =>
  item.attachments?.map((attachment) => ({
    ...attachment,
    type: attachment.type ?? getAttachmentType(attachment.href),
  })) ?? [];
---
<BaseLayout title="About" description={about.summary}>
  <section class="page-head">
    <h1>About</h1>
    <p>{site.title}</p>
  </section>

  <p>{about.summary}</p>
  <div class="hero-links">
    <a class="btn" href={`mailto:${site.email}`}>{site.email}</a>
    <a class="btn" href={site.github}>GitHub</a>
    <a class="btn" href={site.orcid}>ORCID</a>
  </div>

  <h2>Employment</h2>
  <div class="section">
    {employment.map((e) => (
      <div class="entry">
        <div class="entry-head">
          <span class="entry-title">{e.role} · <span class="entry-org">{e.org}</span></span>
          <span class="entry-period">{e.period}</span>
        </div>
        <ul>{e.points.map((p) => <li>{p}</li>)}</ul>
      </div>
    ))}
  </div>

  <h2>Education</h2>
  <div class="section">
    {education.map((e) => (
      <div class="entry">
        <div class="entry-head">
          <span class="entry-title">{e.degree} · <span class="entry-org">{e.org}</span></span>
          <span class="entry-period">{e.period}</span>
        </div>
        {e.detail && <p style="margin: 6px 0 0; color: var(--text-muted); font-size: 0.92rem;">{e.detail}</p>}
      </div>
    ))}
  </div>

  <h2>Research Publications</h2>
  <div class="section">
    {publications.map((p) => (
      <div class="entry">
        <div class="entry-title">{p.title}</div>
        <p style="margin: 4px 0 0; color: var(--text-muted); font-size: 0.9rem;">{p.authors}</p>
        <p style="margin: 2px 0 0; color: var(--text-muted); font-size: 0.88rem;">
          {p.venue}. <a href={p.doi}>DOI ↗</a>
        </p>
      </div>
    ))}
  </div>

  <h2>Skills</h2>
  <div class="section">
    {skills.map((s) => (
      <div class="entry">
        <div class="entry-head"><span class="entry-title">{s.group}</span></div>
        <div class="chips" style="margin-top: 8px;">
          {s.items.map((i) => <span class="chip chip-tech">{i}</span>)}
        </div>
      </div>
    ))}
  </div>

  <h2>Awards & Achievements</h2>
  <div class="section">
    {awards.map((a) => (
      <div class="entry">
        <div class="entry-head">
          <span class="entry-title">{a.title}</span>
          <span class="entry-period">{a.year}</span>
        </div>
        <p style="margin: 4px 0 0; color: var(--text-muted); font-size: 0.9rem;">{a.org}</p>
        {normalizeAttachments(a).length > 0 && (
          <div class="attachment-links" aria-label={`Attachments for ${a.title}`}>
            {normalizeAttachments(a).map((attachment) => (
              <a class={`attachment-link attachment-${attachment.type}`} href={attachment.href} target="_blank" rel="noopener noreferrer">
                {getAttachmentLabel(attachment)} ↗
              </a>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>

  <h2>Certifications</h2>
  <div class="section">
    {certifications.map((c) => (
      <div class="entry">
        <div class="entry-head">
          <span class="entry-title">{c.title}</span>
          <span class="entry-period">{c.year}</span>
        </div>
        <p style="margin: 4px 0 0; color: var(--text-muted); font-size: 0.9rem;">{c.org}</p>
        {normalizeAttachments(c).length > 0 && (
          <div class="attachment-links" aria-label={`Attachments for ${c.title}`}>
            {normalizeAttachments(c).map((attachment) => (
              <a class={`attachment-link attachment-${attachment.type}`} href={attachment.href} target="_blank" rel="noopener noreferrer">
                {getAttachmentLabel(attachment)} ↗
              </a>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>
</BaseLayout>
